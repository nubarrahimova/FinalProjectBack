@model FinalProject.Models.Article

@{
    ViewData["Title"] = Model.Title;
}

<section style="padding:48px 0 72px; background:#f8fbff; min-height:100vh;">
    <div style="max-width:980px; margin:0 auto; padding:0 20px;">

        <div style="background:#ffffff; border:1px solid #edf2f7; border-radius:24px; padding:36px 40px; box-shadow:0 8px 24px rgba(15, 23, 42, 0.04);">
            <a href="/" style="display:inline-flex; align-items:center; gap:8px; margin-bottom:22px; color:#2f80ed; text-decoration:none; font-weight:600; font-size:15px;">
                ← Ana səhifə
            </a>
            <div style="display:flex; align-items:center; gap:14px; margin-bottom:22px; flex-wrap:wrap;">
                @{
                    string doctorImage;

                    if (!string.IsNullOrWhiteSpace(Model.Doctor?.PhotoUrl))
                    {
                        if (Model.Doctor.PhotoUrl.StartsWith("/"))
                        {
                            doctorImage = Model.Doctor.PhotoUrl;
                        }
                        else
                        {
                            doctorImage = "/assets/images/" + Model.Doctor.PhotoUrl;
                        }
                    }
                    else
                    {
                        doctorImage = "/assets/images/xuraman-qaribova.jpg";
                    }
                }

                <img src="@doctorImage"
                     alt="Doctor"
                     width="56"
                     height="56"
                     style="border-radius:50%; object-fit:cover; border:1px solid #e5e7eb; background:#f3f4f6; display:block;"
                     onerror="this.onerror=null; this.src='/assets/images/xuraman-qaribova.jpg';" />

                <div>
                    <div style="font-size:18px; font-weight:700; color:#2f80ed; line-height:1.3;">
                        @(string.IsNullOrWhiteSpace(Model.AuthorName) ? "Müəllif qeyd olunmayıb" : Model.AuthorName)
                    </div>

                    <div style="font-size:15px; color:#6b7280; margin-top:2px;">
                        @(string.IsNullOrWhiteSpace(Model.AuthorSpecialty) ? "İxtisas qeyd olunmayıb" : Model.AuthorSpecialty)
                    </div>
                </div>
            </div>

            <h1 style="margin:0 0 14px; font-size:48px; line-height:1.2; font-weight:800; color:#18212f;">
                @Model.Title
            </h1>

            <div style="margin-bottom:30px; font-size:15px; color:#6b7280;">
                Dərc olunub: @Model.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Summary))
            {
                <div style="margin-bottom:28px; font-size:20px; line-height:1.8; color:#4b5563; font-weight:500;">
                    @Model.Summary
                </div>
            }

            <div style="font-size:18px; line-height:2; color:#1f2937;">
                @Html.Raw(Model.Content)
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        .article-detail-content p,
        div[style*="font-size:18px"] p {
            margin: 0 0 22px;
        }

        .article-detail-content h1,
        .article-detail-content h2,
        .article-detail-content h3,
        .article-detail-content h4,
        div[style*="font-size:18px"] h1,
        div[style*="font-size:18px"] h2,
        div[style*="font-size:18px"] h3,
        div[style*="font-size:18px"] h4 {
            margin: 34px 0 16px;
            color: #18212f;
            line-height: 1.35;
            font-weight: 700;
        }

        div[style*="font-size:18px"] ul,
        div[style*="font-size:18px"] ol {
            margin: 0 0 22px 24px;
            padding: 0;
        }

        div[style*="font-size:18px"] li {
            margin-bottom: 10px;
        }

        div[style*="font-size:18px"] img {
            max-width: 100%;
            height: auto;
            border-radius: 16px;
            margin: 20px 0;
        }

        @@media (max-width: 768px) {
            section[style*="padding:48px 0 72px"] {
                padding: 28px 0 48px !important;
            }

            div[style*="border-radius:24px; padding:36px 40px"] {
                padding: 24px 18px !important;
                border-radius: 18px !important;
            }

            h1[style*="font-size:48px"] {
                font-size: 32px !important;
            }

            div[style*="margin-bottom:28px; font-size:20px"] {
                font-size: 17px !important;
            }

            div[style*="font-size:18px; line-height:2"] {
                font-size: 16px !important;
                line-height: 1.85 !important;
            }
        }
    </style>
}