@model FinalProject.ViewModels.DoctorDetailsVM

@{
    ViewData["Title"] = Model.FullName;
}

@section Styles {
    <link rel="stylesheet" href="~/assets/css/doctor.css" />
    <style>
        .details-page {
            margin-top: 24px;
        }

        .details-card {
            background: #fff;
            border: 1px solid #ececec;
            border-radius: 24px;
            padding: 24px;
            box-shadow: 0 6px 24px rgba(0,0,0,.04);
        }

        .details-top {
            display: flex;
            gap: 24px;
            align-items: flex-start;
            flex-wrap: wrap;
        }

        .details-photo-wrap {
            width: 140px;
            height: 140px;
            border-radius: 24px;
            overflow: hidden;
            flex: 0 0 140px;
            background: #f5f5f5;
        }

        .details-photo {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .details-info {
            flex: 1;
            min-width: 280px;
        }

        .details-name-row {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 12px;
        }

        .details-name {
            font-size: 24px;
            font-weight: 800;
            margin: 0;
        }

        .details-badge {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 999px;
            background: #eef5ff;
            color: #1e73ff;
            font-weight: 700;
            font-size: 14px;
        }

        .details-line {
            margin: 8px 0;
            color: #444;
            font-size: 18px;
        }

            .details-line strong {
                color: #111;
            }

        .details-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 20px;
        }

        .details-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            height: 46px;
            padding: 0 18px;
            border-radius: 14px;
            text-decoration: none;
            font-weight: 700;
            border: 1px solid #d9d9d9;
            color: #222;
            background: #fff;
        }

            .details-btn.primary {
                background: #1e73ff;
                border-color: #1e73ff;
                color: #fff;
            }


        .details-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 20px;
            margin-top: 24px;
        }

        .details-box {
            background: #fff;
            border: 1px solid #ececec;
            border-radius: 24px;
            padding: 24px;
            box-shadow: 0 6px 24px rgba(0,0,0,.04);
        }

            .details-box h3 {
                margin: 0 0 16px;
                font-size: 20px;
                font-weight: 800;
            }

        .details-list {
            list-style: none;
            margin: 0;
            padding: 0;
        }

            .details-list li {
                padding: 10px 0;
                border-bottom: 1px solid #f0f0f0;
                color: #444;
            }

                .details-list li:last-child {
                    border-bottom: 0;
                }

        .schedule-row {
            display: flex;
            justify-content: space-between;
            gap: 12px;
        }

        .schedule-day {
            font-weight: 700;
            color: #222;
        }

        .bio-text {
            color: #444;
            line-height: 1.8;
            margin: 0 0 12px;

            @@media (max-width: 992px) {
                .details-grid {
                    grid-template-columns: 1fr;
                }
            }
            grid-template-columns: 1fr;
        }

        }

        .details-input {
            width: 100%;
            height: 46px;
            border: 1px solid #d9d9d9;
            border-radius: 12px;
            padding: 0 14px;
            font-size: 16px;
            outline: none;
            box-sizing: border-box;
        }

        .result-box {
            background: #f8fbff;
            border: 1px solid #dbeafe;
            border-radius: 16px;
            padding: 16px;
            color: #1f2937;
            line-height: 1.8;
        }
    </style>
}

<div class="container details-page">
    <section class="details-card">
        <div class="details-top">
            <div class="details-photo-wrap">
                <img class="details-photo" src="@Model.PhotoUrl" alt="@Model.FullName" />
            </div>

            <div class="details-info">
                <div class="details-name-row">
                    <h1 class="details-name">@Model.FullName</h1>
                    <span class="details-badge">@Model.Speciality</span>
                </div>

                <div class="details-line">
                    İş stajı (il): <strong>@Model.ExperienceYears</strong>
                </div>

                <div class="details-line">
                    Klinika: <strong>@Model.Clinic</strong>
                </div>

                <div class="details-actions">
                    <a class="details-btn" href="/doctors">← Siyahıya qayıt</a>
                    <a class="details-btn primary" href="/booking/@Model.Slug">Qəbul üçün yazıl</a>
                </div>
            </div>
        </div>
    </section>
    <section class="details-box" style="margin-top: 24px;">
        <h3>Menstrual dövr təqvimi</h3>
        <p class="bio-text">
            Bu sadə hesablayıcı menstrual dövrü izləməyə kömək edir. Həkim məsləhətini əvəz etmir və kontrasepsiya üsulu deyil.
        </p>

        <div style="display:grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap:16px; margin-top:16px;">
            <div>
                <label for="lastPeriodDate" style="display:block; font-weight:700; margin-bottom:8px;">Son menstruasiyanın ilk günü</label>
                <input id="lastPeriodDate" type="date" class="details-input" />
            </div>

            <div>
                <label for="cycleLength" style="display:block; font-weight:700; margin-bottom:8px;">Orta dövr uzunluğu (günlərlə)</label>
                <input id="cycleLength" type="number" class="details-input" value="@Model.CycleLength" min="20" max="40" />
            </div>

            <div>
                <label for="periodLength" style="display:block; font-weight:700; margin-bottom:8px;">Menstruasiya müddəti (günlərlə)</label>
                <input id="periodLength" type="number" class="details-input" value="@Model.PeriodLength" min="2" max="10" />
            </div>
        </div>

        <div style="margin-top:16px;">
            <button type="button" class="details-btn primary" onclick="calculateCycle()">Təxmini tarixləri hesabla</button>
        </div>

        <div id="cycleResult" style="margin-top:20px;"></div>
    </section>
    <section class="details-grid">
        <div class="details-box">
            <h3>Həftəlik cədvəl</h3>
            <ul class="details-list">
                @foreach (var item in Model.Schedule)
                {
                    <li>
                        <div class="schedule-row">
                            <span class="schedule-day">@item.Day</span>
                            <span>@item.Hours</span>
                        </div>
                    </li>
                }
            </ul>
        </div>

        <div class="details-box">
            <h3>Xidmətlər</h3>
            <ul class="details-list">
                @foreach (var service in Model.Services)
                {
                    <li>@service</li>
                }
            </ul>
        </div>

        <div class="details-box">
            <h3>Bioqrafiya</h3>
            @foreach (var line in Model.Biography)
            {
                <p class="bio-text">@line</p>
            }
        </div>
    </section>
</div>

@section Scripts {
    <script>
        function formatDate(date) {
            return date.toLocaleDateString("az-AZ");
        }

        function addDays(date, days) {
            const result = new Date(date);
            result.setDate(result.getDate() + days);
            return result;
        }

        function calculateCycle() {
            const lastPeriodDateValue = document.getElementById("lastPeriodDate").value;
            const cycleLength = parseInt(document.getElementById("cycleLength").value);
            const periodLength = parseInt(document.getElementById("periodLength").value);
            const resultBox = document.getElementById("cycleResult");

            if (!lastPeriodDateValue || !cycleLength || !periodLength) {
                resultBox.innerHTML = '<div class="result-box">Zəhmət olmasa bütün xanaları doldurun.</div>';
                return;
            }

            const lastPeriodDate = new Date(lastPeriodDateValue);
            const nextPeriodDate = addDays(lastPeriodDate, cycleLength);
            const ovulationDate = addDays(lastPeriodDate, cycleLength - 14);
            const fertileStart = addDays(ovulationDate, -5);
            const fertileEnd = addDays(ovulationDate, 1);
            const periodEnd = addDays(lastPeriodDate, periodLength - 1);

            resultBox.innerHTML = `
                <div class="result-box">
                    <div><strong>Son menstruasiya dövrü:</strong> ${formatDate(lastPeriodDate)} - ${formatDate(periodEnd)}</div>
                    <div><strong>Təxmini ovulyasiya günü:</strong> ${formatDate(ovulationDate)}</div>
                    <div><strong>Münbit günlər:</strong> ${formatDate(fertileStart)} - ${formatDate(fertileEnd)}</div>
                    <div><strong>Növbəti menstruasiya tarixi:</strong> ${formatDate(nextPeriodDate)}</div>
                </div>
            `;
        }
    </script>
}