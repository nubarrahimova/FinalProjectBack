@{
    ViewData["Title"] = "Sorğu göndərildi";
}

<section style="padding:60px 0; background:#f8fbff; min-height:100vh;">
    <div style="max-width:700px; margin:0 auto; padding:0 20px;">

        <div style="background:#ffffff;
                    border:1px solid #edf2f7;
                    border-radius:24px;
                    padding:40px;
                    text-align:center;
                    box-shadow:0 10px 30px rgba(15,23,42,0.06);">

            <div style="
                width:70px;
                height:70px;
                margin:0 auto 20px;
                border-radius:50%;
                background:#e8f3ff;
                display:flex;
                align-items:center;
                justify-content:center;
                font-size:32px;">
                ✔
            </div>

            <h1 style="
                margin-bottom:12px;
                font-size:32px;
                font-weight:800;
                color:#18212f;">
                Sorğu uğurla göndərildi
            </h1>

            <p style="
                color:#6b7280;
                font-size:16px;
                margin-bottom:30px;">
                Müraciətiniz uğurla göndərildi. 
                Qısa müddət ərzində sizinlə telefon vasitəsi ilə əlaqə saxlanılacaq.
            </p>

            <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">

                <a href="/doctors"
                   style="
                   padding:12px 22px;
                   border-radius:12px;
                   background:#2f80ed;
                   color:white;
                   text-decoration:none;
                   font-weight:600;">
                    Həkimlərə qayıt
                </a>

                <a href="/"
                   style="
                   padding:12px 22px;
                   border-radius:12px;
                   border:1px solid #dbe3ef;
                   color:#18212f;
                   text-decoration:none;
                   font-weight:600;">
                    Ana səhifə
                </a>

            </div>

        </div>

    </div>
</section>
