<!DOCTYPE html>
<html lang="@(System.Threading.Thread.CurrentThread.CurrentCulture.Name)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @Localizer["SiteName"]</title>

    <link rel="stylesheet" href="~/assets/css/style.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <header class="header">
        <div class="container-header">
            <a class="logo" href="/" aria-label="@Localizer["SiteName"]">@Localizer["SiteName"]</a>

            <div class="header-center">
                <div class="lang-switch" role="group" aria-label="@Localizer["LanguageSelection"]">
                    <a href="/Home/ChangeLanguage?culture=az" class="lng" hreflang="az" lang="az">@Localizer["AZ"]</a>
                    <a href="/Home/ChangeLanguage?culture=ru" class="lng" hreflang="ru" lang="ru">@Localizer["RU"]</a>
                    <a href="/Home/ChangeLanguage?culture=en" class="lng" hreflang="en" lang="en">@Localizer["EN"]</a>
                </div>

                <a class="btn primary nav-cta" href="/doctors" aria-label="@Localizer["BookAppointment"]">@Localizer["BookAppointment"]</a>
            </div>

            <nav class="nav" aria-label="@Localizer["MainNavigation"]">
                <a href="/#articles-home">@Localizer["Articles"]</a>
                <a href="/#about">@Localizer["About"]</a>
                <a href="/#contacts">@Localizer["Contacts"]</a>
                <a href="/#policy">@Localizer["Policy"]</a>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/AdminPanel/Appointments" class="btn-primary">@Localizer["Dashboard"]</a>
                }
                else
                {
                    <a href="/Account/Login" class="btn-outline-primary">@Localizer["DoctorAdminLogin"]</a>
                }
            </nav>
        </div>
    </header>

    <main class="site-main">
        @RenderBody()
    </main>

    <footer class="site-footer-custom">
        <div class="footer-inner">
            <div>© 2026 @Localizer["SiteName"] · @Localizer["AllRightsReserved"]</div>
            <div>@Localizer["SiteCredit"] <a href="/">DevCraft Digital</a>.</div>
            <div>
                @Localizer["Disclaimer"]
            </div>

            <div class="footer-links">
                <a href="/#policy">@Localizer["Disclaimer"]</a>
                <a href="/#policy">@Localizer["PrivacyPolicy"]</a>
            </div>
        </div>
    </footer>

    @RenderSection("Scripts", required: false)

    <!-- ASK ADMIN BUTTON -->
    <button class="ask-admin-btn" type="button" onclick="openAskAdminModal()">?</button>

    <!-- OVERLAY -->
    <div class="ask-admin-overlay" id="askAdminOverlay" onclick="closeAskAdminModal()"></div>

    <!-- MODAL -->
    <div class="ask-admin-modal" id="askAdminModal">
        <div class="ask-admin-modal-box">

            <button class="ask-admin-close" onclick="closeAskAdminModal()">×</button>

            <h2 class="ask-admin-title">Adminə sual verin</h2>

            <form asp-area=""
                  asp-controller="AdminQuestions"
                  asp-action="Send"
                  method="post">

                @Html.AntiForgeryToken()

                <div class="ask-admin-group">
                    <label>Siz kimsiniz?</label>
                    <select name="UserType" class="ask-admin-input">
                        <option value="Pasiyent">Pasiyent</option>
                        <option value="Həkim">Həkim</option>
                        <option value="Klinika nümayəndəsi">Klinika nümayəndəsi</option>
                        <option value="Digər">Digər</option>
                    </select>
                </div>

                <div class="ask-admin-group">
                    <label>Ad, Soyad *</label>
                    <input type="text" name="FullName" class="ask-admin-input" required>
                </div>

                <div class="ask-admin-group">
                    <label>Telefon / WhatsApp *</label>
                    <input type="text" name="Phone" class="ask-admin-input" placeholder="+994..." required>
                </div>

                <div class="ask-admin-group">
                    <label>E-mail</label>
                    <input type="email" name="Email" class="ask-admin-input">
                </div>

                <div class="ask-admin-group">
                    <label>Mövzu *</label>
                    <input type="text" name="Subject" class="ask-admin-input" required>
                </div>

                <div class="ask-admin-group">
                    <label>Mesaj *</label>
                    <textarea name="Message" class="ask-admin-textarea" rows="5" required></textarea>
                </div>

                <button type="submit" class="ask-admin-submit">Göndər</button>

            </form>

        </div>
    </div>

    <script>

        function openAskAdminModal(){

            var modal = document.getElementById("askAdminModal");
            var overlay = document.getElementById("askAdminOverlay");

            modal.style.display = "grid";
            overlay.style.display = "block";

        }

        function closeAskAdminModal(){

            var modal = document.getElementById("askAdminModal");
            var overlay = document.getElementById("askAdminOverlay");

            modal.style.display = "none";
            overlay.style.display = "none";

        }

        document.addEventListener("keydown", function(e){

            if(e.key === "Escape"){
                closeAskAdminModal();
            }

        });

    </script>
</body>
</html>