<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1.0" />
    <title>@ViewData["Title"] - MedZapis</title>

    <link rel="stylesheet" href="~/assets/css/style.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)

</head>
<body>
    <header class="header">
        <div class="container-header">
            <a class="logo" href="/">MedZapis</a>

            <div class="header-center">
                <div class="lang-switch" role="group" aria-label="Language">
                    <a class="lng active" href="?lang=az" aria-current="true">AZ</a>
                    <a class="lng" href="?lang=ru">RU</a>
                    <a class="lng" href="?lang=en">EN</a>
                </div>

                <a class="btn primary nav-cta" href="/doctors">Qəbula yazıl</a>
            </div>

            <nav class="nav" aria-label="Main navigation">
                <a href="/#articles-home">Məqalələr</a>
                <a href="/#about">Haqqında</a>
                <a href="/#contacts">Əlaqə</a>
                <a href="/#policy">Siyasət</a>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/AdminPanel/Appointments" class="btn-primary">Kabinet</a>
                }
                else
                {
                    <a href="/Account/Login" class="btn-outline-primary">Həkim/Admin girişi</a>
                }
            </nav>
        </div>
    </header>

    <main class="site-main">
        @RenderBody()
    </main>

    <footer class="site-footer-custom">
        <div class="footer-inner">
            <div>© 2026 MedZapis · Bütün hüquqlar qorunur</div>
            <div>Sayt daxili resurslarla hazırlanıb — <a href="/">DevCraft Digital</a>.</div>
            <div>
                MedZapis onlayn qeydiyyat üçün pulsuz platformadır. Tibbi xidmətin keyfiyyəti və məzmununa görə
                məsuliyyət müvafiq həkim və ya klinikanın üzərindədir.
            </div>

            <div class="footer-links">
                <a href="/#policy">Diskleymer</a>
                <a href="/#policy">Məxfilik Siyasəti</a>
            </div>
        </div>
    </footer>

    @RenderSection("Scripts", required: false)
</body>
</html>