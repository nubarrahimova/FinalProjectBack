@using FinalProject.Models
@{
    ViewData["Title"] = "Ana səhifə";
    var homeArticles = ViewBag.HomeArticles as List<Article> ?? new List<Article>();
}

<section class="hero">
    <div class="container hero-grid">
        <div class="hero-copy">
            <h1>Onlayn həkim qəbulu — sadə, təhlükəsiz, rəsmi</h1>

            <p class="lead">
                <strong>MedZapis</strong> — özəl mütəxəssislər və klinikalar üçün onlayn qeydiyyat
                platformasıdır. Qaydaların aydınlığına və məlumatların qorunmasına fokuslanırıq ki,
                özünüzü arxayın hiss edəsiniz.
            </p>

            <p class="muted" style="margin-top:12px;">
                Hazırda MedZapis ictimai test rejimindədir. Funksiyaları addım-addım artırırıq.
                Hər hansı nasazlıq görsəniz, zəhmət olmasa
                <a href="mailto:copy4hub@gmail.com">copy4hub@gmail.com</a> ünvanına yazın.
                <br />
                Təşəkkür edirik!
            </p>

            <div class="cta">
                <a class="btn primary" href="/Doctors">Həkim tap</a>
                <button class="btn" id="pricingBtn" type="button">Həkimlər üçün tariflər</button>
            </div>

            <div class="card hero-card" style="margin-top:14px;">
                <ul class="hero-ul">
                    <li class="hero-li">
                        <span class="check">✓</span>
                        <span>
                            Aydın şərtlər: bir səhifədə qısa
                            <a href="#policy">siyasət və diskleymer</a>
                        </span>
                    </li>
                    <li class="hero-li">
                        <span class="check">✓</span>
                        <span>Xatırlatmalar və təqvimə əlavə (ICS)</span>
                    </li>
                    <li class="hero-li">
                        <span class="check">✓</span>
                        <span>Məlumatlar şifrələnir və razılıq olmadan üçüncü tərəflərlə paylaşılmır</span>
                    </li>
                </ul>
            </div>
        </div>

        <div class="hero-visual">
            <div class="phone" aria-label="MedZapis preview">
                <div class="phone-top"></div>
                <div class="screen">
                    <img src="/assets/images/screenshoot_medzapis_az.jpg" alt="MedZapis şəkil" />
                </div>
            </div>
        </div>
    </div>
</section>

<section id="about" class="page-section">
    <div class="container">
        <h2 class="section-title">Xidmət haqqında</h2>

        <p class="section-subtitle">
            MedZapis — xəstələrin həkimə tez yazılması və mütəxəssislərin cədvəli rahat idarə etməsi üçün
            texnoloji platformadır. Biz tibbi xidmət göstərmirik və “həkim–pasiyent” münasibətlərinə
            müdaxilə etmirik.
        </p>

        <div class="three-col-grid" style="margin-top:28px;">
            <div class="soft-card">
                <h3>1–2 dəqiqəyə yazılın</h3>
                <p>Mütəxəssis və vaxt seçin — təsdiq e-poçt / mesencerlə göndərilir.</p>
            </div>

            <div class="soft-card">
                <h3>Təqvim və xatırlatmalar</h3>
                <p>Qəbulu bir kliklə təqvimə əlavə edin. Unutmamaq üçün bildirişlər.</p>
            </div>

            <div class="soft-card">
                <h3>Şəffaflıq</h3>
                <p>Qaydaları əvvəlcədən anlamaq üçün səhifənin sonunda qısa siyasət və diskleymer.</p>
            </div>
        </div>
    </div>
</section>

<section id="faq" class="page-section">
    <div class="container">
        <h2 class="section-title">MedZapis haqqında tez-tez verilən suallar</h2>

        <div class="faq-box">
            <details open>
                <summary>MedZapis xəstələr üçün ödənişlidirmi?</summary>
                <p>
                    Xəstələr üçün MedZapis vasitəsilə onlayn qeydiyyat pulsuzdur. Siz yalnız seçdiyiniz
                    həkimin və ya klinikanın qəbuluna görə ödəniş edirsiniz. MedZapis xəstədən əlavə
                    komissiya almır və qiymətlərə qarışmır.
                </p>
            </details>

            <details>
                <summary>Tətbiq yükləməliyəmmi?</summary>
                <p>
                    Xeyr. MedZapis adi sayt kimi işləyir. Mobil brauzerdə “Ana ekrana əlavə et”
                    funksiyasından istifadə edərək tətbiq kimi də qura bilərsiniz.
                </p>
            </details>

            <details>
                <summary>MedZapis həkimlər üçün nə verir?</summary>
                <p>
                    Həkim üçün MedZapis kiçik onlayn kabinetdir: qeydiyyatların vahid təqvimi,
                    pasiyentlərin siyahısı və sadə statistika. Bu, iş gününü planlaşdırmağa,
                    qeydiyyatları toplamağa və gəlməmələri azaltmağa kömək edir.
                </p>
            </details>

            <details>
                <summary>Tibbi xidmətə görə kim məsuliyyət daşıyır?</summary>
                <p>
                    Tibbi xidmətin keyfiyyətinə və məzmununa görə məsuliyyət birbaşa həkimin və ya
                    klinikanın üzərindədir.
                </p>
            </details>

            <details>
                <summary>Məlumatlarım nə dərəcədə təhlükəsizdir?</summary>
                <p>
                    Biz yalnız qeydiyyat üçün lazım olan minimum məlumatları toplayırıq.
                    Məlumatlar şifrələnmiş kanallar vasitəsilə ötürülür və qorunan serverlərdə saxlanılır.
                </p>
            </details>
        </div>
    </div>
</section>

<section id="articles-home" class="home-articles-section">
    <div class="container">
        <div class="home-articles-header">
            <h2>Həkimlərimizin məqalələri</h2>
            <p>
                Praktiki həkimlərdən qısa izahlar: simptomlar, analizlər və nə vaxt
                mütəxəssisə müraciət etmək lazımdır.
            </p>
        </div>

        <div class="home-articles-grid">
            @foreach (var item in homeArticles)
            {
                <article class="home-article-card">
                    <div class="home-article-top">
                        <img src="/images/doctor.png"
                             alt="Doctor"
                             class="home-article-avatar"
                             onerror="this.style.display='none';" />

                        <div class="home-article-meta">
                            <h6>
                                @(string.IsNullOrWhiteSpace(item.AuthorName)
                                                            ? "Müəllif qeyd olunmayıb"
                                                            : item.AuthorName)
                                                                          </h6>

                            <span>
                                @(string.IsNullOrWhiteSpace(item.AuthorSpecialty)
                                                            ? "İxtisas qeyd olunmayıb"
                                                            : item.AuthorSpecialty)
                                                                               </span>
                                                                           </div>
                                                                       </div>

                    <h3 class="home-article-title">
                        <a href="/Articles/@item.Slug">
                            @item.Title
                        </a>
                    </h3>

                    <p class="home-article-summary">
                        @(
                                            string.IsNullOrWhiteSpace(item.Summary)
                                            ? "Qısa məzmun əlavə edilməyib."
                                            : (item.Summary.Length > 170
                                            ? item.Summary.Substring(0, 170) + "..."
                                            : item.Summary)
                                            )
                </p>

                    <a href="/Articles/@item.Slug" class="home-article-link">
                        Daha çox oxu →
                    </a>
                </article>
                        }
        </div>

        <div class="home-articles-footer">
            <a class="home-articles-button" href="/Articles">
                Bütün məqalələr
            </a>
        </div>
    </div>
</section>

<section id="contacts" class="page-section">
    <div class="container">
        <h2 class="section-title">Əlaqə</h2>

        <div class="two-col-grid">
            <div class="soft-card">
                <h3>Bizimlə əlaqə</h3>
                <p>E-poçt: <a href="mailto:copy4hub@gmail.com">copy4hub@gmail.com</a></p>
                <p>Telegram: <a href="https://t.me/webdevis">@@webdevis</a></p>
            </div>

            <div class="soft-card">
                <h3>Mütəxəssislər üçün</h3>
                <p>
                    Həkim/klinika kimi qoşulmaq istəyirsiniz? İxtisasınızı və üstünlük verdiyiniz
                    qrafiki yazın. Sürətli start üçün kömək edəcəyik.
                </p>
            </div>
        </div>
    </div>
</section>

<section id="policy" class="page-section">
    <div class="container">
        <h2 class="section-title">Qısa siyasət və məlumatların emalı</h2>

        <div class="soft-card">
            <p><strong>Nələri toplayırıq:</strong> ad, əlaqə məlumatları və seçilmiş qəbul vaxtı.</p>
            <p><strong>Saxlama:</strong> məlumatlar təhlükəsiz serverlərdə saxlanılır.</p>
            <p><strong>Məlumatların ötürülməsi:</strong> qəbulu təşkil etmək üçün yalnız zəruri informasiyanı həkim/klinikaya veririk.</p>
        </div>
    </div>
</section>

<div class="modal-backdrop" id="pricingModal" aria-hidden="true">
    <div class="pricing-modal" role="dialog" aria-modal="true" aria-labelledby="pricingTitle">
        <div class="pricing-modal-header">
            <h2 id="pricingTitle">Həkimlər üçün tariflər</h2>
            <button class="pricing-close" id="pricingClose" type="button" aria-label="Bağla">✕</button>
        </div>

        <div class="pricing-modal-body">
            <p class="pricing-intro">
                MedZapis üçün yalnız bir tarif var: bütün imkanlar ayda cəmi <strong>1 AZN</strong>.
                İlin sonuna qədər xidmətdən pulsuz istifadə edib hər şeyi rahat sınaqdan keçirə bilərsiniz.
            </p>

            <div class="pricing-plan-card">
                <div class="pricing-plan-top">
                    <div>
                        <div class="pricing-plan-name">BASIC</div>
                        <div class="pricing-plan-price">1 AZN <span>/ ay</span></div>
                    </div>

                    <div class="pricing-badge">Aktiv plan</div>
                </div>

                <ul class="pricing-feature-list">
                    <li>Həkim üçün şəxsi səhifə (unikal URL) + QR-kod</li>
                    <li>Onlayn qeydiyyat</li>
                    <li>Həkim kabineti (PWA): əsas ekrana əlavə etmə, son məlumatların oflayn görünüşü</li>
                    <li>Müraciətlər siyahısı: tarix/vaxt, status, şərh</li>
                    <li>Təqvimə abunə (ICS/Webcal)</li>
                    <li>Adminlə əlaqə: “Gələnlər” və “Adminə yaz”</li>
                    <li>Pasiyentlər (Micro-CRM): yazılardan avtomatik toplama, təkrarlananların birləşdirilməsi, axtarış/filtr, ilk/son ziyarət, ziyarətlərin sayğacı</li>
                    <li>Analitika: qeydiyyatlar və unikal pasiyentlər; Line/Bar qrafik; 7/30/90 gün diapazonu</li>
                    <li>Kabinetdə RU / AZ / EN dilləri</li>
                    <li>Yeni yazılar barədə həkimə e-mail — daxildir</li>
                    <li>CSV ixracı (pasiyentlər/müraciətlər)</li>
                    <li>Pasiyent üzrə qeydlər, teqlər və statuslar (inkişafdadır)</li>
                    <li>24/7 prioritet dəstək</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<button class="ask-admin-btn" id="askAdminBtn" aria-label="Adminə sual verin">?</button>
@section Scripts {
    <script>
        const pricingBtn = document.getElementById("pricingBtn");
        const pricingModal = document.getElementById("pricingModal");
        const pricingClose = document.getElementById("pricingClose");

        if (pricingBtn && pricingModal) {
            pricingBtn.addEventListener("click", function () {
                pricingModal.classList.add("active");
                pricingModal.setAttribute("aria-hidden", "false");
                document.body.style.overflow = "hidden";
            });
        }

        if (pricingClose && pricingModal) {
            pricingClose.addEventListener("click", function () {
                pricingModal.classList.remove("active");
                pricingModal.setAttribute("aria-hidden", "true");
                document.body.style.overflow = "";
            });
        }

        if (pricingModal) {
            pricingModal.addEventListener("click", function (e) {
                if (e.target === pricingModal) {
                    pricingModal.classList.remove("active");
                    pricingModal.setAttribute("aria-hidden", "true");
                    document.body.style.overflow = "";
                }
            });
        }

        document.addEventListener("keydown", function (e) {
            if (e.key === "Escape" && pricingModal?.classList.contains("active")) {
                pricingModal.classList.remove("active");
                pricingModal.setAttribute("aria-hidden", "true");
                document.body.style.overflow = "";
            }
        });
    </script>
}