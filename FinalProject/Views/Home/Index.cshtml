@using FinalProject.Models
@{
    ViewData["Title"] = "Ana səhifə";
    var homeArticles = ViewBag.HomeArticles as List<Article> ?? new List<Article>();
}

<section class="hero">
    <div class="container hero-grid">
        <div class="hero-copy">
            <h1>@Localizer["HeroTitle"]</h1>

            <p class="lead">
                <strong>@Localizer["SiteName"]</strong> — @Localizer["HeroDescription"]
            </p>

            <p class="muted" style="margin-top:12px;">
                @Localizer["TestModeMessage1"]
                <a href="mailto:copy4hub@gmail.com">copy4hub@gmail.com</a> @Localizer["TestModeMessage2"]
                <br />
                @Localizer["Thanks"]
            </p>

            <div class="cta">
                <a class="btn primary" href="/Doctors">@Localizer["FindDoctor"]</a>
                <button class="btn" id="pricingBtn" type="button">@Localizer["PricingForDoctors"]</button>
            </div>

            <div class="card hero-card" style="margin-top:14px;">
                <ul class="hero-ul">
                    <li class="hero-li">
                        <span class="check">✓</span>
                        <span>
                            @Localizer["Feature1"]
                            <a href="#policy">@Localizer["PolicyLink"]</a>
                        </span>
                    </li>
                    <li class="hero-li">
                        <span class="check">✓</span>
                        <span>@Localizer["Feature2"]</span>
                    </li>
                    <li class="hero-li">
                        <span class="check">✓</span>
                        <span>@Localizer["Feature3"]</span>
                    </li>
                </ul>
            </div>
        </div>

        <div class="hero-visual">
            <div class="phone" aria-label="@Localizer["PhonePreview"]">
                <div class="phone-top"></div>
                <div class="screen">
                    <img src="/assets/images/screenshoot_medzapis_az.jpg" alt="@Localizer["ScreenshotAlt"]" />
                </div>
            </div>
        </div>
    </div>
</section>

<section id="about" class="page-section">
    <div class="container">
        <h2 class="section-title">@Localizer["AboutTitle"]</h2>

        <p class="section-subtitle">
            @Localizer["AboutDescription"]
        </p>

        <div class="three-col-grid" style="margin-top:28px;">
            <div class="soft-card">
                <h3>@Localizer["Feature1Title"]</h3>
                <p>@Localizer["Feature1Description"]</p>
            </div>

            <div class="soft-card">
                <h3>@Localizer["Feature2Title"]</h3>
                <p>@Localizer["Feature2Description"]</p>
            </div>

            <div class="soft-card">
                <h3>@Localizer["Feature3Title"]</h3>
                <p>@Localizer["Feature3Description"]</p>
            </div>
        </div>
    </div>
</section>

<section id="faq" class="page-section">
    <div class="container">
        <h2 class="section-title">@Localizer["FAQTitle"]</h2>

        <div class="faq-box">
            <details open>
                <summary>@Localizer["FAQ1Question"]</summary>
                <p>
                    @Localizer["FAQ1Answer"]
                </p>
            </details>

            <details>
                <summary>@Localizer["FAQ2Question"]</summary>
                <p>
                    @Localizer["FAQ2Answer"]
                </p>
            </details>

            <details>
                <summary>@Localizer["FAQ3Question"]</summary>
                <p>
                    @Localizer["FAQ3Answer"]
                </p>
            </details>

            <details>
                <summary>@Localizer["FAQ4Question"]</summary>
                <p>
                    @Localizer["FAQ4Answer"]
                </p>
            </details>

            <details>
                <summary>@Localizer["FAQ5Question"]</summary>
                <p>
                    @Localizer["FAQ5Answer"]
                </p>
            </details>
        </div>
    </div>
</section>

<section id="articles-home" class="home-articles-section">
    <div class="container">
        <div class="home-articles-header">
            <h2>@Localizer["ArticlesTitle"]</h2>
            <p>
                @Localizer["ArticlesDescription"]
            </p>
        </div>

        <div class="home-articles-grid">
            @if (homeArticles != null && homeArticles.Count > 0)
            {
                @foreach (var item in homeArticles)
                {
                    <article class="home-article-card">
                        <div class="home-article-top">
                            <img src="/images/doctor.png"
                                 alt="@Localizer["Doctor"]"
                                 class="home-article-avatar"
                                 onerror="this.style.display='none';" />

                            <div class="home-article-meta">
                                <h6>
                                    @(string.IsNullOrWhiteSpace(item.AuthorName)
                                                                ? Localizer["AuthorNotSpecified"].Value
                                                                : item.AuthorName)
                                                                              </h6>

                                <span>
                                    @(string.IsNullOrWhiteSpace(item.AuthorSpecialty)
                                                                ? Localizer["SpecialtyNotSpecified"].Value
                                                                : item.AuthorSpecialty)
                                                                                   </span>
                                                                               </div>
                                                                           </div>

                        <h3 class="home-article-title">
                            <a href="/Articles/@item.Slug">
                                @item.Title
                            </a>
                        </h3>

                        <p class="home-article-summary">
                            @(
                                                string.IsNullOrWhiteSpace(item.Summary)
                                                ? Localizer["NoSummary"].Value
                                                : (item.Summary.Length > 170
                                                ? item.Summary.Substring(0, 170) + "..."
                                                : item.Summary)
                                                )
                    </p>

                        <a href="/Articles/@item.Slug" class="home-article-link">
                            @Localizer["ReadMore"] →
                        </a>
                    </article>
                        }
            }
        </div>

        <div class="home-articles-footer">
            <a class="home-articles-button" href="/Articles">
                @Localizer["AllArticles"]
            </a>
        </div>
    </div>
</section>

<section id="contacts" class="page-section">
    <div class="container">
        <h2 class="section-title">@Localizer["ContactsTitle"]</h2>

        <div class="two-col-grid">
            <div class="soft-card">
                <h3>@Localizer["ContactUs"]</h3>
                <p>@Localizer["Email"]: <a href="mailto:copy4hub@gmail.com">copy4hub@gmail.com</a></p>
                <p>Telegram: <a href="https://t.me/webdevis">@@webdevis</a></p>
            </div>

            <div class="soft-card">
                <h3>@Localizer["ForSpecialists"]</h3>
                <p>
                    @Localizer["ForSpecialistsDescription"]
                </p>
            </div>
        </div>
    </div>
</section>

<section id="policy" class="page-section">
    <div class="container">
        <h2 class="section-title">@Localizer["PolicyTitle"]</h2>

        <div class="soft-card">
            <p><strong>@Localizer["WhatWeCollect"]:</strong> @Localizer["WhatWeCollectDescription"]</p>
            <p><strong>@Localizer["Storage"]:</strong> @Localizer["StorageDescription"]</p>
            <p><strong>@Localizer["DataTransfer"]:</strong> @Localizer["DataTransferDescription"]</p>
        </div>
    </div>
</section>

<div class="modal-backdrop" id="pricingModal" aria-hidden="true">
    <div class="pricing-modal" role="dialog" aria-modal="true" aria-labelledby="pricingTitle">
        <div class="pricing-modal-header">
            <h2 id="pricingTitle">@Localizer["PricingForDoctors"]</h2>
            <button class="pricing-close" id="pricingClose" type="button" aria-label="@Localizer["Close"]">✕</button>
        </div>

        <div class="pricing-modal-body">
            <p class="pricing-intro">
                @Localizer["PricingIntro"]
            </p>

            <div class="pricing-plan-card">
                <div class="pricing-plan-top">
                    <div>
                        <div class="pricing-plan-name">@Localizer["BasicPlan"]</div>
                        <div class="pricing-plan-price">@Localizer["PlanPrice"] <span>/ @Localizer["Month"]</span></div>
                    </div>

                    <div class="pricing-badge">@Localizer["ActivePlan"]</div>
                </div>

                <ul class="pricing-feature-list">
                    <li>@Localizer["Feature1"]</li>
                    <li>@Localizer["Feature2"]</li>
                    <li>@Localizer["Feature3"]</li>
                    <li>@Localizer["Feature4"]</li>
                    <li>@Localizer["Feature5"]</li>
                    <li>@Localizer["Feature6"]</li>
                    <li>@Localizer["Feature7"]</li>
                    <li>@Localizer["Feature8"]</li>
                    <li>@Localizer["Feature9"]</li>
                    <li>@Localizer["Feature10"]</li>
                    <li>@Localizer["Feature11"]</li>
                    <li>@Localizer["Feature12"]</li>
                    <li>@Localizer["Feature13"]</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<button class="ask-admin-btn" id="askAdminBtn" aria-label="@Localizer["AskAdmin"]">?</button>
@section Scripts {
    <script>
        const pricingBtn = document.getElementById("pricingBtn");
        const pricingModal = document.getElementById("pricingModal");
        const pricingClose = document.getElementById("pricingClose");

        if (pricingBtn && pricingModal) {
            pricingBtn.addEventListener("click", function () {
                pricingModal.classList.add("active");
                pricingModal.setAttribute("aria-hidden", "false");
                document.body.style.overflow = "hidden";
            });
        }

        if (pricingClose && pricingModal) {
            pricingClose.addEventListener("click", function () {
                pricingModal.classList.remove("active");
                pricingModal.setAttribute("aria-hidden", "true");
                document.body.style.overflow = "";
            });
        }

        if (pricingModal) {
            pricingModal.addEventListener("click", function (e) {
                if (e.target === pricingModal) {
                    pricingModal.classList.remove("active");
                    pricingModal.setAttribute("aria-hidden", "true");
                    document.body.style.overflow = "";
                }
            });
        }

        document.addEventListener("keydown", function (e) {
            if (e.key === "Escape" && pricingModal?.classList.contains("active")) {
                pricingModal.classList.remove("active");
                pricingModal.setAttribute("aria-hidden", "true");
                document.body.style.overflow = "";
            }
        });
    </script>
}