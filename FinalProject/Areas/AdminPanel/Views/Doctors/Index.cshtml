@model List<FinalProject.Models.Doctor>

@{
    ViewData["Title"] = "Həkimlər";
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h3 style="font-weight:700; color:#2c3e50;">Həkimlər</h3>
            <p style="color:#6c757d; margin-bottom:0;">Sistemdə qeydiyyatda olan həkimlər</p>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0" style="border-radius:16px;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th style="padding-left:20px;">#</th>
                        <th>Ad Soyad</th>
                        <th>Klinika</th>
                        <th>Təcrübə</th>
                        <th>İxtisas</th>
                        <th>Slug</th>
                    </tr>
                </thead>
                <tbody>

                    @if (Model != null && Model.Any())
                    {
                        int count = 1;

                        @foreach (var item in Model)
                        {
                            <tr>
                                <td style="padding-left:20px;">@count</td>

                                <td>
                                    <strong>@item.FullName</strong>
                                </td>

                                <td>
                                    @(string.IsNullOrEmpty(item.Clinic) ? "-" : item.Clinic)
                                </td>

                                <td>
                                    @item.ExperienceYears il
                                </td>

                                <td>
                                    @(item.Speciality != null ? item.Speciality.Name : "-")
                                </td>

                                <td>
                                    <span class="text-muted">@item.Slug</span>
                                </td>
                            </tr>

                            count++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                Həkim tapılmadı
                            </td>
                        </tr>
                    }

                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .table thead th {
        font-weight: 700;
        color: #2c3e50;
        border-bottom: 2px solid #eef2f7;
    }

    .table td {
        padding-top: 16px;
        padding-bottom: 16px;
    }

    .table tbody tr {
        transition: all .2s;
    }

        .table tbody tr:hover {
            background: #f8fbff;
        }
</style>