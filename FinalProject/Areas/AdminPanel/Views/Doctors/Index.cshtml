@model List<FinalProject.Models.Doctor>

@{
    ViewData["Title"] = "Həkimlər";
    Layout = "~/Areas/AdminPanel/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header mb-4">
    <h3 class="page-title">Həkimlər</h3>
    <p style="color:#6c757d; margin-bottom:0;">Sistemdə olan bütün həkimlər</p>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Şəkil</th>
                        <th>Ad Soyad</th>
                        <th>İxtisas</th>
                        <th>Staj</th>
                        <th>Klinika</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var doctor in Model)
                        {
                            var doctorImage = !string.IsNullOrWhiteSpace(doctor.PhotoUrl)
                            ? (doctor.PhotoUrl.StartsWith("/") ? doctor.PhotoUrl : "/assets/images/" + doctor.PhotoUrl)
                            : "/assets/images/xuraman-qaribova.jpg";

                            <tr>
                                <td>
                                    <img src="@doctorImage"
                                         alt="@doctor.FullName"
                                         style="width:52px; height:52px; border-radius:50%; object-fit:cover; border:1px solid #e5e7eb;"
                                         onerror="this.onerror=null; this.src='/assets/images/xuraman-qaribova.jpg';" />
                                </td>
                                <td>@doctor.FullName</td>
                                <td>@(doctor.Speciality != null ? doctor.Speciality.Name : "-")</td>
                                <td>@doctor.ExperienceYears il</td>
                                <td>@(!string.IsNullOrWhiteSpace(doctor.Clinic) ? doctor.Clinic : "-")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center">Həkim tapılmadı.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>