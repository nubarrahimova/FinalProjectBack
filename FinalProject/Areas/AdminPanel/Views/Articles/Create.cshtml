@model FinalProject.ViewModels.AdminPanel.ArticleFormVM

<div class="row">
    <div class="col-md-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Yeni məqalə</h4>

                <form asp-action="Create" asp-controller="Articles" asp-area="AdminPanel" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="form-group">
                        <label>Başlıq</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label>Qısa məzmun</label>
                        <textarea asp-for="Summary" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="form-group">
                        <label>Məzmun</label>
                        <textarea asp-for="Content" class="form-control" rows="10"></textarea>
                        <span asp-validation-for="Content" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label>Şəkil seç</label>
                        <input asp-for="CoverImageFile" type="file" class="form-control" />
                    </div>

                    <div class="form-group" style="margin-bottom:16px;">
                        <div style="display:flex; align-items:center; gap:10px;">
                            <input asp-for="IsPublished" type="checkbox" style="width:18px; height:18px;" />
                            <label asp-for="IsPublished" style="margin:0;">Yayımla</label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary mr-2">Yadda saxla</button>
                    <a href="/AdminPanel/Articles" class="btn btn-light">Geri qayıt</a>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}