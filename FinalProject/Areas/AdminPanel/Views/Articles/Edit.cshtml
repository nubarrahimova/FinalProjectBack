@model FinalProject.ViewModels.AdminPanel.ArticleFormVM

<div class="row">
    <div class="col-md-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Məqaləni redaktə et</h4>

                <form action="/AdminPanel/Articles/Edit/@Model.Id" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="form-group">
                        <label>Başlıq</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label>Müəllifin ad, Soyadı</label>
                        <input asp-for="AuthorName" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>Müəllif ixtisası</label>
                        <input asp-for="AuthorSpecialty" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label>Qısa məzmun</label>
                        <textarea asp-for="Summary" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="form-group">
                        <label>Məzmun</label>
                        <textarea asp-for="Content" class="form-control" rows="10"></textarea>
                        <span asp-validation-for="Content" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label>Yeni şəkil seç</label>
                        <input asp-for="CoverImageFile" type="file" class="form-control" id="coverImageInput" accept="image/*" />
                    </div>

                    @* //sekil onizlemesi ucun *@
                    <div class="form-group">
                        <label>Şəkil önizləməsi</label><br />
                        <img id="coverPreview"
                             src="@(Model.ExistingImageUrl ?? "")"
                             alt="Article image"
                             style="max-width:220px; @(string.IsNullOrWhiteSpace(Model.ExistingImageUrl) ? "display:none;" : "display:block;") border-radius:10px; border:1px solid #ddd; padding:4px; cursor:pointer;" />
                    </div>
                    @* //sekilin basanda boyumesi *@
                    <div id="imageModal"
                         style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.75); z-index:9999; justify-content:center; align-items:center; padding:20px;">
                        <img id="modalImage"
                             src="@(Model.ExistingImageUrl ?? "")"
                             alt="Böyük şəkil"
                             style="max-width:90%; max-height:90%; border-radius:12px; box-shadow:0 0 20px rgba(0,0,0,0.35);" />
                    </div>

                    <div class="form-group" style="margin-bottom:16px;">
                        <div style="display:flex; align-items:center; gap:10px;">
                            <input asp-for="IsPublished" type="checkbox" style="width:18px; height:18px;" />
                            <label asp-for="IsPublished" style="margin:0;">Yayımla</label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary mr-2">Yadda saxla</button>
                    <a href="/AdminPanel/Articles" class="btn btn-light">Geri qayıt</a>
                </form>

            </div>
        </div>
    </div>
</div>

@*// text-editor *@
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script 
        src="https://cdn.ckeditor.com/4.22.1/standard/ckeditor.js"></script>

    <script>
              CKEDITOR.replace('Content');

        @* //sekil onizlemesi ucun *@

        const coverImageInput = document.getElementById('coverImageInput');
        const coverPreview = document.getElementById('coverPreview');
        const imageModal = document.getElementById('imageModal');
        const modalImage = document.getElementById('modalImage');

        if (coverImageInput) {
            coverImageInput.addEventListener('change', function (event) {
                const file = event.target.files[0];

                if (!file) {
                    coverPreview.style.display = 'none';
                    coverPreview.src = '';
                    modalImage.src = '';
                    return;
                }

                const reader = new FileReader();

                reader.onload = function (e) {
                    coverPreview.src = e.target.result;
                    modalImage.src = e.target.result;
                    coverPreview.style.display = 'block';
                };

                reader.readAsDataURL(file);
            });
        }

        if (coverPreview) {
            coverPreview.addEventListener('click', function () {
                if (coverPreview.src) {
                    imageModal.style.display = 'flex';
                }
            });
        }

        if (imageModal) {
            imageModal.addEventListener('click', function () {
                imageModal.style.display = 'none';
            });
        }
    </script>
}