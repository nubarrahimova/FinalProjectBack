@model List<FinalProject.Models.Article>

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
                    <h4 class="card-title" style="margin:0;">Məqalələr</h4>

                    <a href="/AdminPanel/Articles/Create" class="btn btn-primary">
                        Yeni məqalə
                    </a>
                </div>

                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Başlıq</th>
                                <th>Slug</th>
                                <th>Status</th>
                                <th>Tarix</th>
                                <th>Hərəkətlər</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td>@item.Title</td>
                                    <td>@item.Slug</td>
                                    <td>
                                        @if (item.IsPublished)
                                        {
                                            <label class="badge badge-success" style="color:black;">Yayımlanıb</label>
                                        }
                                        else
                                        {
                                            <label class="badge badge-warning" style="color:black;">Draft</label>
                                        }
                                    </td>
                                    <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>
                                        <a href="/AdminPanel/Articles/Edit/@item.Id" class="btn btn-sm btn-warning">
                                            Edit
                                        </a>

                                        <form action="/AdminPanel/Articles/Delete/@item.Id" method="post" style="display:inline-block; margin-left:6px;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-danger"
                                                    onclick="return confirm('Silmək istədiyinizə əminsiniz?')">
                                                Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    </div>
</div>