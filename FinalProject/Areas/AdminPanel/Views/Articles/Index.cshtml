@model List<FinalProject.Models.Article>

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">

                <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:16px; margin-bottom:20px; flex-wrap:wrap;">
                    <h4 class="card-title" style="margin:0;">Məqalələr</h4>

                    <form method="get" action="/AdminPanel/Articles" style="margin:0; flex:1; min-width:320px; max-width:620px;">
                        <div style="display:flex; gap:10px; align-items:center;">
                            <input type="text"
                                   name="search"
                                   value="@ViewBag.Search"
                                   class="form-control"
                                   placeholder="Başlıq, slug, müəllif və ya ixtisas axtar..." />

                            <button type="submit" class="btn btn-primary">
                                Axtar
                            </button>

                            <a href="/AdminPanel/Articles" class="btn btn-light">
                                Təmizlə
                            </a>
                        </div>
                    </form>

                    <a href="/AdminPanel/Articles/Create" class="btn btn-primary">
                        Yeni məqalə
                    </a>
                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Şəkil</th>
                                <th>Müəllif</th>
                                <th>İxtisas</th>
                                <th>Başlıq</th>
                                <th style="white-space:nowrap; min-width:140px;">Tarix</th>
                                <th>Status</th>
                                <th style="white-space:nowrap; min-width:250px;">Hərəkətlər</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Id</td>

                                    <td>
                                        <img src="@(string.IsNullOrWhiteSpace(item.CoverImageUrl)
                                                                                         ? "/images/default-article.png"
                                                                                         : item.CoverImageUrl)"
                                         alt="@item.Title"
                                         style="width:60px; height:60px; object-fit:cover; border-radius:8px;" />
                                </td>

                                    <td style="min-width:120px;">
                                        @(string.IsNullOrWhiteSpace(item.AuthorName) ? "-" : item.AuthorName)
                                    </td>

                                    <td style="min-width:120px;">
                                        @(string.IsNullOrWhiteSpace(item.AuthorSpecialty) ? "-" : item.AuthorSpecialty)
                                    </td>

                                    <td style="max-width:260px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"
                                        title="@item.Title">
                                        @item.Title
                                    </td>
                                    <td class="article-date-cell">
                                        <div class="article-date">
                                            <span class="date-line">@item.CreatedAt.ToString("dd.MM.yyyy")</span>
                                            <span class="time-line">@item.CreatedAt.ToString("HH:mm")</span>
                                        </div>
                                    </td>

                                    <td style="white-space:nowrap;">

                                        <form action="/AdminPanel/Articles/ToggleStatus/@item.Id" method="post" style="margin:0;">
                                            @Html.AntiForgeryToken()


                                        @if (item.IsPublished)
                                            {
                                                <button type="submit"
                                                        class="btn btn-sm"
                                                        style="background:#16a34a; color:white; min-width:110px; border:none;">
                                                    Yayımlanıb
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit"
                                                        class="btn btn-sm"
                                                        style="background:#f59e0b; color:white; min-width:110px; border:none;">
                                                    Draft
                                                </button>
                                            }
                                        </form>
                             
                                    <td style="white-space:nowrap; min-width:250px;">
                                        <div style="display:flex; gap:8px; align-items:center;">
                                            <a href="/AdminPanel/Articles/Edit/@item.Id"
                                               class="btn btn-sm btn-warning"
                                               style="min-width:70px;">
                                                Edit
                                            </a>

                                            <form action="/AdminPanel/Articles/Delete/@item.Id"
                                                  method="post"
                                                  style="margin:0;">
                                                @Html.AntiForgeryToken()

                                                <button type="submit"
                                                        class="btn btn-sm btn-danger"
                                                        style="min-width:70px;"
                                                        onclick="return confirm('Silmək istədiyinizə əminsiniz?')">
                                                    Delete
                                                </button>
                                            </form>

                                            <a href="/Articles/@item.Slug"
                                               target="_blank"
                                               class="btn btn-sm"
                                               style="background:#0ea5e9; color:white; min-width:75px;">
                                                Preview
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    </div>
</div>
<style>
    .article-title-cell {
        max-width: 260px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .article-date-cell {
        min-width: 110px;
        white-space: nowrap;
    }

    .article-date {
        display: flex;
        flex-direction: column;
        line-height: 1.2;
    }

        .article-date .date-line {
            font-weight: 600;
            color: #212529;
        }

        .article-date .time-line {
            font-size: 13px;
            color: #6c757d;
            margin-top: 2px;
        }
</style>