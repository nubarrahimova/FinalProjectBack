@using FinalProject.Models
@model List<Appointment>

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Randevular</h4>
                @* //axtaris *@
                <form method="get" action="/AdminPanel/Appointments" style="margin-bottom:20px;">
                    <div style="display:flex; gap:10px;">

                        <input type="text"
                               name="search"
                               value="@ViewBag.Search"
                               class="form-control"
                               placeholder="Ad, soyad və ya telefon axtar..." />

                        <button type="submit" class="btn btn-primary">
                            Axtar
                        </button>

                        <a href="/AdminPanel/Appointments" class="btn btn-secondary">
                            Təmizlə
                        </a>

                    </div>
                </form>

                <div class="appointment-filter">

                    <a href="/AdminPanel/Appointments"
                       class="filter-btn @(ViewBag.SelectedStatus == null ? "active" : "")">
                        Hamısı
                    </a>

                    <a href="/AdminPanel/Appointments?status=New"
                       class="filter-btn @(ViewBag.SelectedStatus == "New" ? "active" : "")">
                        Yeni
                    </a>

                    <a href="/AdminPanel/Appointments?status=Approved"
                       class="filter-btn @(ViewBag.SelectedStatus == "Approved" ? "active" : "")">
                        Təsdiqləndi
                    </a>

                    <a href="/AdminPanel/Appointments?status=Rejected"
                       class="filter-btn @(ViewBag.SelectedStatus == "Rejected" ? "active" : "")">
                        Rədd edildi
                    </a>

                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Ad</th>
                                <th>Soyad</th>
                                <th>Telefon</th>
                                <th>Tarix</th>
                                <th>Vaxt</th>
                                <th>Status</th>
                                <th>Hərəkətlər</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.FirstName</td>
                                    <td>@item.LastName</td>
                                    <td>@item.Phone</td>
                                    <td>@item.Date.ToString("yyyy-MM-dd")</td>
                                    <td>@item.Time</td>
                                    <td>
                                        @if (item.Status == "Approved")
                                        {
                                            <span class="custom-status-badge custom-status-approved">
                                                <i class="mdi mdi-check-circle-outline"></i>
                                                Təsdiqləndi
                                            </span>
                                        }
                                        else if (item.Status == "Rejected")
                                        {
                                            <span class="custom-status-badge custom-status-rejected">
                                                <i class="mdi mdi-close-circle-outline"></i>
                                                Rədd edildi
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="custom-status-badge custom-status-pending">
                                                <i class="mdi mdi-timer-sand"></i>
                                                Yeni
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <div class="appointment-action-group">

                                            <form action="/AdminPanel/Appointments/Approve/@item.Id" method="post" style="margin:0;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="custom-action-btn custom-action-approve">
                                                    <i class="mdi mdi-check-bold"></i>
                                                    Təsdiqlə
                                                </button>
                                            </form>

                                            <form action="/AdminPanel/Appointments/Reject/@item.Id" method="post" style="margin:0;">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="custom-action-btn custom-action-reject">
                                                    <i class="mdi mdi-close-thick"></i>
                                                    Rədd et
                                                </button>
                                            </form>

                                            @if (User.IsInRole("Admin"))
                                            {
                                                <form action="/AdminPanel/Appointments/Delete/@item.Id" method="post" style="margin:0;">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit"
                                                            class="custom-action-btn custom-action-delete"
                                                            onclick="return confirm('Silmək istədiyinizə əminsiniz?')">
                                                        <i class="mdi mdi-trash-can-outline"></i>
                                                        Sil
                                                    </button>
                                                </form>
                                            }

                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    </div>
</div>
