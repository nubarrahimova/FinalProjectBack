@model List<FinalProject.Models.Appointment>

@{
    ViewData["Title"] = "Randevular";

    string? selectedStatus = ViewBag.SelectedStatus as string;
    string? search = ViewBag.Search as string;

    int currentPage = ViewBag.CurrentPage != null ? (int)ViewBag.CurrentPage : 1;
    int totalPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
    int totalCount = ViewBag.TotalCount != null ? (int)ViewBag.TotalCount : 0;
}

<div class="row">
    <div class="col-12">
        <div class="page-card">
            <div class="page-card-header">
                <div>
                    <h4 class="page-title">Randevular</h4>
                    <p class="page-subtitle">Randevu siyahısı, filter və səhifələmə</p>
                </div>
            </div>

            <form method="get" asp-area="AdminPanel" asp-controller="Appointments" asp-action="Index" class="appointment-search-form">
                <div class="search-input-group">
                    <input type="text"
                           name="search"
                           value="@search"
                           class="form-control"
                           placeholder="Ad, soyad və ya telefon axtar..." />

                    <input type="hidden" name="status" value="@selectedStatus" />

                    <button type="submit" class="btn btn-primary px-4">
                        Axtar
                    </button>

                    <a href="/admin/appointments" class="btn btn-secondary px-4">
                        Təmizlə
                    </a>
                </div>
            </form>

            <div class="appointment-filter">
                <a href="@Url.Action("Index", "Appointments", new { area = "AdminPanel", status = (string?)null, search = search, page = 1 })"
                   class="filter-btn @(string.IsNullOrWhiteSpace(selectedStatus) ? "active" : "")">
                    Hamısı
                </a>

                <a href="@Url.Action("Index", "Appointments", new { area = "AdminPanel", status = "New", search = search, page = 1 })"
                   class="filter-btn @(selectedStatus == "New" ? "active" : "")">
                    Yeni
                </a>

                <a href="@Url.Action("Index", "Appointments", new { area = "AdminPanel", status = "Approved", search = search, page = 1 })"
                   class="filter-btn @(selectedStatus == "Approved" ? "active" : "")">
                    Təsdiqləndi
                </a>

                <a href="@Url.Action("Index", "Appointments", new { area = "AdminPanel", status = "Rejected", search = search, page = 1 })"
                   class="filter-btn @(selectedStatus == "Rejected" ? "active" : "")">
                    Rədd edildi
                </a>
            </div>

            <div class="result-info">
                Ümumi nəticə sayı: <strong>@totalCount</strong>
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Ad</th>
                            <th>Soyad</th>
                            <th>Telefon</th>

                            @if (User.IsInRole("Admin"))
                            {
                                <th>Həkim</th>
                            }

                            <th>Tarix</th>
                            <th>Vaxt</th>
                            <th>Status</th>
                            <th>Hərəkətlər</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.FirstName</td>
                                    <td>@item.LastName</td>
                                    <td>@item.Phone</td>

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <td>@(item.Doctor != null ? item.Doctor.FullName : "-")</td>
                                    }

                                    <td>@item.Date.ToString("yyyy-MM-dd")</td>
                                    <td>@item.Time</td>

                                    <td>
                                        @if (item.Status == "Approved")
                                        {
                                            <span class="custom-status-badge custom-status-approved">
                                                <i class="mdi mdi-check-circle-outline"></i>
                                                Təsdiqləndi
                                            </span>
                                        }
                                        else if (item.Status == "Rejected")
                                        {
                                            <span class="custom-status-badge custom-status-rejected">
                                                <i class="mdi mdi-close-circle-outline"></i>
                                                Rədd edildi
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="custom-status-badge custom-status-pending">
                                                <i class="mdi mdi-timer-sand"></i>
                                                Yeni
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        <div class="appointment-action-group">

                                            <form asp-area="AdminPanel"
                                                  asp-controller="Appointments"
                                                  asp-action="Approve"
                                                  method="post"
                                                  style="margin:0;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="page" value="@currentPage" />
                                                <input type="hidden" name="status" value="@selectedStatus" />
                                                <input type="hidden" name="search" value="@search" />

                                                <button type="submit" class="custom-action-btn custom-action-approve">
                                                    <i class="mdi mdi-check-bold"></i>
                                                    Təsdiqlə
                                                </button>
                                            </form>

                                            <form asp-area="AdminPanel"
                                                  asp-controller="Appointments"
                                                  asp-action="Reject"
                                                  method="post"
                                                  style="margin:0;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="page" value="@currentPage" />
                                                <input type="hidden" name="status" value="@selectedStatus" />
                                                <input type="hidden" name="search" value="@search" />

                                                <button type="submit" class="custom-action-btn custom-action-reject">
                                                    <i class="mdi mdi-close-thick"></i>
                                                    Rədd et
                                                </button>
                                            </form>

                                            @if (User.IsInRole("Admin"))
                                            {
                                                <form asp-area="AdminPanel"
                                                      asp-controller="Appointments"
                                                      asp-action="Delete"
                                                      method="post"
                                                      style="margin:0;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <input type="hidden" name="page" value="@currentPage" />
                                                    <input type="hidden" name="status" value="@selectedStatus" />
                                                    <input type="hidden" name="search" value="@search" />

                                                    <button type="submit"
                                                            class="custom-action-btn custom-action-delete"
                                                            onclick="return confirm('Silmək istədiyinizə əminsiniz?')">
                                                        <i class="mdi mdi-trash-can-outline"></i>
                                                        Sil
                                                    </button>
                                                </form>
                                            }

                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-4 text-muted">
                                    Randevu tapılmadı.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (totalPages > 1)
            {
                <div class="pagination-wrapper">
                    <nav>
                        <ul class="custom-pagination">
                            <li>
                                <a class="page-link-custom @(currentPage == 1 ? "disabled" : "")"
                                   href="@Url.Action("Index", "Appointments", new { area = "AdminPanel", page = currentPage - 1, status = selectedStatus, search = search })">
                                    Əvvəlki
                                </a>
                            </li>

                            @for (int i = 1; i <= totalPages; i++)
                            {
                                <li>
                                    <a class="page-link-custom @(i == currentPage ? "active" : "")"
                                       href="@Url.Action("Index", "Appointments", new { area = "AdminPanel", page = i, status = selectedStatus, search = search })">
                                        @i
                                    </a>
                                </li>
                            }

                            <li>
                                <a class="page-link-custom @(currentPage == totalPages ? "disabled" : "")"
                                   href="@Url.Action("Index", "Appointments", new { area = "AdminPanel", page = currentPage + 1, status = selectedStatus, search = search })">
                                    Növbəti
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .page-card {
        background: #ffffff;
        border-radius: 16px;
        padding: 22px;
        box-shadow: 0 8px 22px rgba(0,0,0,0.06);
        border: 1px solid #eef2f7;
    }

    .page-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
        gap: 12px;
    }

    .page-title {
        margin: 0;
        font-size: 24px;
        font-weight: 700;
        color: #2c3e50;
    }

    .page-subtitle {
        margin: 4px 0 0 0;
        color: #6c757d;
        font-size: 13px;
    }

    .appointment-search-form {
        margin-bottom: 16px;
    }

    .search-input-group {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

        .search-input-group .form-control {
            min-width: 260px;
            flex: 1;
            border-radius: 10px;
        }

    .appointment-filter {
        display: flex;
        gap: 10px;
        margin-bottom: 16px;
        flex-wrap: wrap;
    }

    .filter-btn {
        padding: 8px 14px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        border: 1px solid #dfe3e8;
        color: #344054;
        background: #f9fafb;
        transition: 0.2s ease;
    }

        .filter-btn:hover {
            background: #eef2f6;
            text-decoration: none;
            color: #344054;
        }

        .filter-btn.active {
            background: #3b82f6;
            color: white;
            border-color: #3b82f6;
        }

    .result-info {
        font-size: 13px;
        color: #6b7280;
        margin-bottom: 16px;
    }

    .table thead th {
        font-weight: 700;
        color: #2c3e50;
        border-bottom: 2px solid #eef2f7;
        padding-top: 14px;
        padding-bottom: 14px;
        white-space: nowrap;
    }

    .table td {
        vertical-align: middle;
        padding-top: 16px;
        padding-bottom: 16px;
    }

    .table tbody tr {
        transition: background-color 0.2s ease;
    }

        .table tbody tr:hover {
            background-color: #f8fbff !important;
        }

    .custom-status-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        min-width: 125px;
        padding: 7px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.2px;
    }

        .custom-status-badge i {
            font-size: 14px;
        }

    .custom-status-approved {
        background-color: #eaf8ef;
        color: #198754;
        border: 1px solid #bfe7cc;
    }

    .custom-status-rejected {
        background-color: #fdecec;
        color: #dc3545;
        border: 1px solid #f2b8be;
    }

    .custom-status-pending {
        background-color: #fff8e1;
        color: #b78103;
        border: 1px solid #f3df9b;
    }

    .appointment-action-group {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .custom-action-btn {
        border: none;
        border-radius: 8px;
        padding: 7px 12px;
        font-size: 12px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        min-width: 95px;
        justify-content: center;
        transition: background-color 0.2s ease;
    }

        .custom-action-btn i {
            font-size: 14px;
        }

    .custom-action-approve {
        background: #eaf8ef;
        color: #198754;
        border: 1px solid #bfe7cc;
    }

        .custom-action-approve:hover {
            background: #dff3e7;
        }

    .custom-action-reject {
        background: #fdecec;
        color: #dc3545;
        border: 1px solid #f2b8be;
    }

        .custom-action-reject:hover {
            background: #fadfe1;
        }

    .custom-action-delete {
        background: #f1f3f5;
        color: #212529;
        border: 1px solid #d9dee3;
    }

        .custom-action-delete:hover {
            background: #e4e8ec;
        }

    .pagination-wrapper {
        margin-top: 22px;
        display: flex;
        justify-content: center;
    }

    .custom-pagination {
        list-style: none;
        display: flex;
        gap: 8px;
        padding: 0;
        margin: 0;
        flex-wrap: wrap;
    }

    .page-link-custom {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 42px;
        height: 42px;
        padding: 0 14px;
        border-radius: 10px;
        border: 1px solid #dfe3e8;
        background: #ffffff;
        color: #344054;
        text-decoration: none;
        font-weight: 600;
        font-size: 13px;
        transition: 0.2s ease;
    }

        .page-link-custom:hover {
            background: #eef2f6;
            text-decoration: none;
            color: #344054;
        }

        .page-link-custom.active {
            background: #3b82f6;
            border-color: #3b82f6;
            color: #ffffff;
        }

        .page-link-custom.disabled {
            pointer-events: none;
            opacity: 0.45;
        }
</style>