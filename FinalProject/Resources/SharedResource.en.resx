    <value>Book in 1-2 minutes</value>
  </data>
  <data name="Feature1Description" xml:space="preserve">
    <value>Choose a specialist and time — confirmation is sent via email/messenger.</value>
  </data>
  <data name="Feature2Title" xml:space="preserve">
